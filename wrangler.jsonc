{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "powertracker",
  "main": "worker.js",
  "compatibility_date": "2026-05-12",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "app",
    "binding": "ASSETS",
    "run_worker_first": ["/tiles/*"]
  }
}
